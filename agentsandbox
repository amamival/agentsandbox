from __future__ import annotations

import fnmatch
import json
import os
from datetime import datetime, timezone

from mitmproxy import http

ALLOWED_HOSTS_FILE = os.environ["AGENTSANDBOX_ALLOWED_HOSTS"]
REQUEST_LOG = os.environ["AGENTSANDBOX_REQUEST_LOG"]
GITHUB_TOKEN = os.environ.get("AGENTSANDBOX_GITHUB_TOKEN", "")


def normalize_host(value: str) -> str:
    host = value.strip().lower().rstrip(".")
    if host.startswith("[") and "]" in host:
        host = host[1 : host.index("]")]
    elif ":" in host:
        host = host.split(":", 1)[0]
    return host


class AgentSandboxProxy:
    def __init__(self) -> None:
        self.allowed_hosts = []
        self.allowed_hosts_mtime = None

    def load_allowed_hosts(self) -> None:
        try:
            stat_result = os.stat(ALLOWED_HOSTS_FILE)
        except FileNotFoundError:
            self.allowed_hosts = []
            self.allowed_hosts_mtime = None
            return
        if self.allowed_hosts_mtime == stat_result.st_mtime_ns:
            return
        loaded = []
        with open(ALLOWED_HOSTS_FILE, "r", encoding="utf-8") as handle:
            for raw_line in handle:
                line = raw_line.strip().lower()
                if not line or line.startswith("#"):
                    continue
                loaded.append(line)
        self.allowed_hosts = loaded
        self.allowed_hosts_mtime = stat_result.st_mtime_ns

    def allow_host(self, host: str) -> bool:
        self.load_allowed_hosts()
        return any(fnmatch.fnmatch(host, pattern) for pattern in self.allowed_hosts)

    def log_request(self, flow: http.HTTPFlow, filter_action: str, filter_reason: str) -> None:
        injected = flow.metadata.get("agentsandbox_injected", [])
        entry = {
            "time": datetime.now(timezone.utc).isoformat().replace("+00:00", "Z"),
            "method": flow.request.method,
            "url": flow.request.pretty_url,
            "host": flow.metadata.get("agentsandbox_host", normalize_host(flow.request.pretty_host)),
            "status": flow.response.status_code if flow.response else None,
            "filter": {"action": filter_action, "reason": filter_reason},
            "credential_injection": injected,
            "redaction": [],
        }
        with open(REQUEST_LOG, "a", encoding="utf-8") as handle:
            handle.write(json.dumps(entry, sort_keys=True))
            handle.write("\n")
        flow.metadata["agentsandbox_logged"] = True

    def requestheaders(self, flow: http.HTTPFlow) -> None:
        host = normalize_host(flow.request.pretty_host)
        flow.metadata["agentsandbox_host"] = host
        flow.metadata["agentsandbox_injected"] = []
        if flow.request.method != "CONNECT" and host == "api.github.com" and GITHUB_TOKEN:
            if "authorization" not in flow.request.headers:
                flow.request.headers["Authorization"] = f"Bearer {GITHUB_TOKEN}"
                flow.metadata["agentsandbox_injected"] = [{"name": "github", "target": "api.github.com"}]
        if self.allow_host(host):
            flow.metadata["agentsandbox_filter"] = ("allow", "")
            return
        flow.metadata["agentsandbox_filter"] = ("block", "host_not_allowed")
        flow.response = http.Response.make(
            403,
            b"blocked by agentsandbox\n",
            {"Content-Type": "text/plain; charset=utf-8"},
        )
        self.log_request(flow, "block", "host_not_allowed")

    def response(self, flow: http.HTTPFlow) -> None:
        if flow.metadata.get("agentsandbox_logged"):
            return
        filter_action, filter_reason = flow.metadata.get("agentsandbox_filter", ("allow", ""))
        self.log_request(flow, filter_action, filter_reason)


addons = [AgentSandboxProxy()]
EOF
