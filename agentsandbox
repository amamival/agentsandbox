#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SRC_DIR="$(cd -- "$(dirname -- "$SCRIPT_PATH")" && pwd -P)"
TEMPLATE_DIR="$SRC_DIR/template"
if [[ ! -d "$TEMPLATE_DIR" ]]; then
  TEMPLATE_DIR="$(cd -- "$SRC_DIR/../share/agentsandbox/template" && pwd -P)"
fi

APP_NAME="agentsandbox"
DEFAULT_PROFILE="${AGENTSANDBOX_PROFILE:-default}"
URI="${LIBVIRT_DEFAULT_URI:-qemu:///session}"
VERSION="${AGENTSANDBOX_VERSION:-0.0.0-dev}"
RUNTIME_LOG_ROTATE_BYTES="${AGENTSANDBOX_LOG_ROTATE_BYTES:-10485760}"
PROXY_PORT="${AGENTSANDBOX_PROXY_PORT:-3128}"

function die() {
  echo "${APP_NAME}: $*" >&2
  exit 1
}

function usage() {
  cat <<'EOF'
usage: agentsandbox [help|version|doctor|init|build|up|down|kill|pause|unpause|destroy|ps|ssh|exec|logs|stats|wait]
                    [mount|unmount|port|allow-domain|unallow-domain|proxy-logs]

  help                Show help
  version             Show version
  doctor              Show diagnostics

  init                Create .agentsandbox/ and copy the initial template files
  build               Build the selected guest system into the instance sysroot
  up                  Rebuild and start a VM; fails if it is already running
  down                Tear down the VM gracefully
  kill                Forcibly stop the VM
  pause               Pause a running VM
  unpause             Resume a paused VM
  destroy             Delete the guest system while preserving persistent data

  ps                  Show status of the selected VM
  ssh                 Connect to a running VM
  exec                Execute a command in a running VM, or attach if omitted
  logs                Show guest journal logs
  stats               Show libvirt domain statistics
  wait                Wait for the selected VM to stop

  mount               Add a mount now and on future starts, or show current mounts
  unmount             Remove a mount now and on future starts

  port                Print the host port for a published guest port
  allow-domain        Add a domain or glob to allowed_hosts
  unallow-domain      Remove a domain or glob from allowed_hosts
  proxy-logs          Follow request logs
EOF
}

function nssudo() {
  unshare --map-root-user --setuid=0 --setgid=0 "$@"
}

function prepare() {
  local data_dir="$1" state_dir="$2" runtime_dir="$3" machine_id="$4"

  install -d \
    "$data_dir/sysroot" \
    "$data_dir/persistent/home/vscode" \
    "$data_dir/persistent/proxy/mitmproxy" \
    "$data_dir/persistent/workspace"
  install -d "$state_dir/logs"
  touch "$state_dir/logs/runtime.log" "$state_dir/logs/requests.jsonl"
  if [[ -n "$runtime_dir" ]]; then
    install -d "$runtime_dir/virtiofs"
    touch "$runtime_dir/lock"
  fi

  if [[ -e "$data_dir/machine-id" ]]; then
    [[ "$(tr -d '\n' < "$data_dir/machine-id")" == "$machine_id" ]] || die "machine-id mismatch in $data_dir"
  else
    printf '%s\n' "$machine_id" > "$data_dir/machine-id"
  fi
}

function fetch_nixos_dockerhub() {
  local sysroot="$1" repo="nixos/nix" tag="latest" arch="amd64" os="linux"
  local registry_endpoint="https://registry-1.docker.io/v2" token manifests manifest manifest_digest blobsums blobsum

  token="$(
    curl -fsSL "https://auth.docker.io/token?service=registry.docker.io&scope=repository:${repo}:pull" | jq -r .token
  )"
  manifests="$(
    curl -fsSL -H "Authorization: Bearer ${token}" "${registry_endpoint}/${repo}/manifests/${tag}"
  )"
  manifest_digest="$(
    jq -r ".manifests[] | select(.platform.architecture == \"${arch}\" and .platform.os == \"${os}\") | .digest" \
      <<<"$manifests"
  )"
  manifest="$(
    curl -fsSL -H "Authorization: Bearer ${token}" "${registry_endpoint}/${repo}/manifests/${manifest_digest}"
  )"
  blobsums="$(jq -r '.layers[].digest' <<<"$manifest")"
  while read -r blobsum; do
    [[ -n "$blobsum" ]] || continue
    {
      IFS= read -r -N 2 magic || die "empty registry layer ${blobsum}"
      if [[ "$magic" == $'\x1f\x8b' ]]; then
        { printf '%s' "$magic"; cat; } | gzip -dc | nssudo tar xf - -C "$sysroot"
      else
        { printf '%s' "$magic"; cat; } | nssudo tar xf - -C "$sysroot"
      fi
    } < <(curl -fsSL -H "Authorization: Bearer ${token}" "${registry_endpoint}/${repo}/blobs/${blobsum}")
  done <<<"$blobsums"
}

function install_nixos() {
  local sysroot="$1" active_config_dir="$2" nixos_configuration="$3"
  local staged_flake="$sysroot/tmp/active-flake"
  local inner_toplevel=""

  rm -rf "$staged_flake"
  mkdir -p "$staged_flake"
  cp -a "$active_config_dir"/. "$staged_flake/"
  inner_toplevel="$(
    nssudo bwrap \
      --bind "$sysroot" / \
      --ro-bind /etc/resolv.conf /etc/resolv.conf \
      --proc /proc \
      --dev /dev \
      --perms 1777 --tmpfs /dev/shm \
      /nix/var/nix/profiles/default/bin/nix \
        --extra-experimental-features 'nix-command flakes' \
        build \
        --no-link \
        --print-out-paths \
        "/tmp/active-flake#nixosConfigurations.${nixos_configuration}.config.system.build.toplevel"
  )"
  printf '%s\n' "${sysroot}${inner_toplevel}"
}

function ensure_system() {
  local sysroot="$1" active_config_dir="$2" nixos_configuration="$3"

  [[ -d "$sysroot/nix/store" ]] || fetch_nixos_dockerhub "$sysroot"
  install_nixos "$sysroot" "$active_config_dir" "$nixos_configuration"
}

function running_pid() {
  local domain_name="$1" state=""

  state="$(virsh -c "$URI" domstate "$domain_name" 2>/dev/null || true)"
  if [[ "$state" == "running" || "$state" == "paused" ]]; then
    printf '%s\n' "$domain_name"
    return 0
  fi
  return 1
}

function require_running_pid() {
  local domain_name="$1"

  running_pid "$domain_name" || die "VM is not running"
}

function sandbox_exec() {
  local ssh_port="$1"
  shift || true

  if [[ "$#" -eq 0 ]]; then
    exec ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -p "$ssh_port" vscode@127.0.0.1
  fi
  exec ssh -t -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -p "$ssh_port" vscode@127.0.0.1 -- "$@"
}

function mount_workspace() {
  local helper_pid="$1" persistent_dir="$2" mounts_file="$3" startup_root="$4" startup_name="$5" mutable="$6"

  if [[ -n "$helper_pid" ]] && kill -0 "$helper_pid" 2>/dev/null; then
    nsenter -t "$helper_pid" -m -- bash "$SCRIPT_PATH" __sync-mounts-inner \
      "$persistent_dir" "$mounts_file" "$startup_root" "$startup_name" "$mutable"
  fi
}

function unmount_workspace() {
  local helper_pid="$1" persistent_dir="$2" mounts_file="$3" startup_root="$4" startup_name="$5" mutable="$6"

  if [[ -n "$helper_pid" ]] && kill -0 "$helper_pid" 2>/dev/null; then
    nsenter -t "$helper_pid" -m -- bash "$SCRIPT_PATH" __sync-mounts-inner \
      "$persistent_dir" "$mounts_file" "$startup_root" "$startup_name" "$mutable"
  fi
}

function main() {
  local cmd="${1:-}" global_flag="0"

  case "$cmd" in
    help|-h|--help)
      usage
      ;;
    version)
      printf '%s\n' "$VERSION"
      ;;
    __resolve-active-config)
      local resolve_from="${2:-$PWD}" search_dir="" local_config_dir="" global_config_dir=""
      local startup_workspace_root="" startup_workspace_name="" config_scope=""

      search_dir="$(readlink -f "$resolve_from")"
      while :; do
        if [[ -f "$search_dir/.agentsandbox/flake.nix" ]]; then
          local_config_dir="$search_dir/.agentsandbox"
          startup_workspace_root="$search_dir"
          startup_workspace_name="$(basename "$search_dir")"
          config_scope="local"
          break
        fi
        [[ "$search_dir" == "/" ]] && break
        search_dir="$(dirname "$search_dir")"
      done

      if [[ -n "$local_config_dir" ]]; then
        printf 'ACTIVE_CONFIG_DIR=%q\n' "$local_config_dir"
        printf 'STARTUP_WORKSPACE_ROOT=%q\n' "$startup_workspace_root"
        printf 'STARTUP_WORKSPACE_NAME=%q\n' "$startup_workspace_name"
        printf 'CONFIG_SCOPE=%q\n' "$config_scope"
        return 0
      fi

      global_config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/agentsandbox"
      if [[ -f "$global_config_dir/flake.nix" ]]; then
        startup_workspace_root="$(readlink -f "$resolve_from")"
        startup_workspace_name="$(basename "$startup_workspace_root")"
        printf 'ACTIVE_CONFIG_DIR=%q\n' "$global_config_dir"
        printf 'STARTUP_WORKSPACE_ROOT=%q\n' "$startup_workspace_root"
        printf 'STARTUP_WORKSPACE_NAME=%q\n' "$startup_workspace_name"
        printf 'CONFIG_SCOPE=%q\n' "global"
        return 0
      fi

      die "no active config found; run '${APP_NAME} init' or '${APP_NAME} init --global'"
      ;;
    __ensure-active-config)
      local ensure_from="${2:-$PWD}" search_dir="" global_config_dir=""

      search_dir="$(readlink -f "$ensure_from")"
      while :; do
        if [[ -f "$search_dir/.agentsandbox/flake.nix" ]]; then
          exec bash "$SCRIPT_PATH" __resolve-active-config "$ensure_from"
        fi
        [[ "$search_dir" == "/" ]] && break
        search_dir="$(dirname "$search_dir")"
      done

      global_config_dir="${XDG_CONFIG_HOME:-$HOME/.config}/agentsandbox"
      if [[ ! -f "$global_config_dir/flake.nix" ]]; then
        bash "$SCRIPT_PATH" init --global >/dev/null
      fi
      exec bash "$SCRIPT_PATH" __resolve-active-config "$ensure_from"
      ;;
    __resolve-instance)
      local startup_workspace_root="$2" active_config_dir="$3" profile_name="$4"
      local xdg_data_home="" xdg_state_home="" runtime_base="" machine_id="" instance_name="" instance_id="" uuid=""

      xdg_data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
      xdg_state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
      runtime_base="${XDG_RUNTIME_DIR:-}"
      machine_id="$(
        printf '%s\0%s\0%s\0' \
          "$(readlink -f "$startup_workspace_root")" \
          "$(readlink -f "$active_config_dir")" \
          "$profile_name" \
          | sha256sum \
          | awk '{print substr($1, 1, 32)}'
      )"
      instance_name="$(basename "$startup_workspace_root")"
      instance_id="${instance_name}-${machine_id}"
      uuid="${machine_id:0:8}-${machine_id:8:4}-${machine_id:12:4}-${machine_id:16:4}-${machine_id:20:12}"

      printf 'PROFILE_NAME=%q\n' "$profile_name"
      printf 'INSTANCE_NAME=%q\n' "$instance_name"
      printf 'INSTANCE_ID=%q\n' "$instance_id"
      printf 'MACHINE_ID=%q\n' "$machine_id"
      printf 'DOMAIN_UUID=%q\n' "$uuid"
      printf 'DATA_DIR=%q\n' "${xdg_data_home}/agentsandbox/${instance_id}"
      printf 'STATE_DIR=%q\n' "${xdg_state_home}/agentsandbox/${instance_id}"
      if [[ -n "$runtime_base" ]]; then
        printf 'RUNTIME_DIR=%q\n' "${runtime_base}/agentsandbox/${instance_id}"
      else
        printf 'RUNTIME_DIR=%q\n' ""
      fi
      printf 'DOMAIN_NAME=%q\n' "agentsandbox-${instance_id}"
      ;;
    __eval-profile)
      local config_dir="$2" profile_name="$3" nixos_configuration="" mutable_json="" memory_json="" vcpus_json="" port_json=""
      local opensnitch_enabled_json="" opensnitch_address=""

      nixos_configuration="$(nix eval --raw "${config_dir}#sandboxConfigurations.${profile_name}.nixosConfiguration")"
      mutable_json="$(nix eval --json "${config_dir}#sandboxConfigurations.${profile_name}.mutableSandboxConfig")"
      memory_json="$(nix eval --json "${config_dir}#sandboxConfigurations.${profile_name}.memoryMiB")"
      vcpus_json="$(nix eval --json "${config_dir}#sandboxConfigurations.${profile_name}.vcpus")"
      port_json="$(nix eval --json "${config_dir}#sandboxConfigurations.${profile_name}.portForwards")"
      opensnitch_enabled_json="$(
        nix eval --json "${config_dir}#nixosConfigurations.${nixos_configuration}.config.services.opensnitch.enable"
      )"
      opensnitch_address="$(
        nix eval --raw "${config_dir}#nixosConfigurations.${nixos_configuration}.config.services.opensnitch.settings.Server.Address"
      )"

      printf 'NIXOS_CONFIGURATION=%q\n' "$nixos_configuration"
      printf 'MUTABLE_SANDBOX_CONFIG=%q\n' "$(jq -r . <<<"$mutable_json")"
      printf 'MEMORY_MIB=%q\n' "$(jq -r . <<<"$memory_json")"
      printf 'VCPUS=%q\n' "$(jq -r . <<<"$vcpus_json")"
      printf 'PORT_FORWARDS_JSON=%q\n' "$port_json"
      printf 'OPENSNITCH_ENABLED=%q\n' "$(jq -r . <<<"$opensnitch_enabled_json")"
      printf 'OPENSNITCH_ADDRESS=%q\n' "$opensnitch_address"
      ;;
    __state)
      local state_from="${2:-$PWD}" profile_name="${3:-$DEFAULT_PROFILE}"
      local ACTIVE_CONFIG_DIR="" STARTUP_WORKSPACE_ROOT="" STARTUP_WORKSPACE_NAME="" CONFIG_SCOPE=""
      local PROFILE_NAME="" INSTANCE_NAME="" INSTANCE_ID="" MACHINE_ID="" DOMAIN_UUID="" DATA_DIR="" STATE_DIR=""
      local RUNTIME_DIR="" DOMAIN_NAME="" NIXOS_CONFIGURATION="" MUTABLE_SANDBOX_CONFIG="" MEMORY_MIB="" VCPUS=""
      local PORT_FORWARDS_JSON="" OPENSNITCH_ENABLED="" OPENSNITCH_ADDRESS=""

      eval "$("$SCRIPT_PATH" __resolve-active-config "$state_from")"
      eval "$("$SCRIPT_PATH" __resolve-instance "$STARTUP_WORKSPACE_ROOT" "$ACTIVE_CONFIG_DIR" "$profile_name")"
      eval "$("$SCRIPT_PATH" __eval-profile "$ACTIVE_CONFIG_DIR" "$PROFILE_NAME")"
      printf 'ACTIVE_CONFIG_DIR=%q\n' "$ACTIVE_CONFIG_DIR"
      printf 'STARTUP_WORKSPACE_ROOT=%q\n' "$STARTUP_WORKSPACE_ROOT"
      printf 'STARTUP_WORKSPACE_NAME=%q\n' "$STARTUP_WORKSPACE_NAME"
      printf 'CONFIG_SCOPE=%q\n' "$CONFIG_SCOPE"
      printf 'PROFILE_NAME=%q\n' "$PROFILE_NAME"
      printf 'INSTANCE_NAME=%q\n' "$INSTANCE_NAME"
      printf 'INSTANCE_ID=%q\n' "$INSTANCE_ID"
      printf 'MACHINE_ID=%q\n' "$MACHINE_ID"
      printf 'DOMAIN_UUID=%q\n' "$DOMAIN_UUID"
      printf 'DATA_DIR=%q\n' "$DATA_DIR"
      printf 'STATE_DIR=%q\n' "$STATE_DIR"
      printf 'RUNTIME_DIR=%q\n' "$RUNTIME_DIR"
      printf 'DOMAIN_NAME=%q\n' "$DOMAIN_NAME"
      printf 'NIXOS_CONFIGURATION=%q\n' "$NIXOS_CONFIGURATION"
      printf 'MUTABLE_SANDBOX_CONFIG=%q\n' "$MUTABLE_SANDBOX_CONFIG"
      printf 'MEMORY_MIB=%q\n' "$MEMORY_MIB"
      printf 'VCPUS=%q\n' "$VCPUS"
      printf 'PORT_FORWARDS_JSON=%q\n' "$PORT_FORWARDS_JSON"
      printf 'OPENSNITCH_ENABLED=%q\n' "$OPENSNITCH_ENABLED"
      printf 'OPENSNITCH_ADDRESS=%q\n' "$OPENSNITCH_ADDRESS"
      ;;
    __ensure-startup-mount)
      local active_config_dir="$2" startup_workspace_root="$3" startup_workspace_name="$4" mounts_file="" startup_line=""

      mounts_file="${active_config_dir}/mounts"
      [[ -e "$mounts_file" ]] || cp "$TEMPLATE_DIR/mounts" "$mounts_file"
      startup_line="$(printf '%s\t%s' "$(readlink -f "$startup_workspace_root")" "$startup_workspace_name")"
      if awk -F $'\t' -v name="$startup_workspace_name" -v root="$(readlink -f "$startup_workspace_root")" '
        /^[[:space:]]*#/ || NF == 0 { next }
        ($2 == name && $1 != root) || ($1 == root && $2 != name) { exit 1 }
      ' "$mounts_file"; then
        :
      else
        die "startup workspace mount conflicts with an existing mounts entry"
      fi
      if ! grep -Fxq -- "$startup_line" "$mounts_file" 2>/dev/null; then
        printf '%s\n' "$startup_line" >> "$mounts_file"
      fi
      ;;
    __mount-helper)
      local persistent_dir="$2" runtime_log="$3"

      mount --make-rprivate /
      mkdir -p "$persistent_dir/home/vscode" "$persistent_dir/workspace"
      printf '%s mount-helper ready %s\n' "$(date -Iseconds)" "$persistent_dir" >> "$runtime_log"
      exec sleep infinity
      ;;
    __sync-mounts-inner)
      local persistent_dir="$2" mounts_file="$3" startup_root="$4" startup_name="$5" mutable="$6"
      local mountinfo_line="" mountpoint_path="" src="" guest_name="" dst=""

      mkdir -p "$persistent_dir/home/vscode" "$persistent_dir/workspace"
      while read -r mountinfo_line; do
        [[ -n "$mountinfo_line" ]] || continue
        mountpoint_path="${mountinfo_line%% *}"
        if mountpoint -q "$mountpoint_path"; then
          umount "$mountpoint_path" >/dev/null 2>&1 || true
        fi
      done < <(
        awk -v root="$persistent_dir/workspace" '$5 ~ ("^" root "(/|$)") { print $5 }' /proc/self/mountinfo | sort -r
      )

      while IFS=$'\t' read -r src guest_name; do
        [[ -n "${src:-}" ]] || continue
        [[ "${src:0:1}" == "#" ]] && continue
        [[ -n "${guest_name:-}" ]] || die "invalid mounts entry: ${src}"
        [[ "$guest_name" != */* ]] || die "guest mount name must not contain /: ${guest_name}"
        [[ -e "$src" ]] || die "mount source does not exist: ${src}"
        dst="$persistent_dir/workspace/$guest_name"

        mkdir -p "$dst"
        mount --rbind "$src" "$dst"
        if [[ "$mutable" == "false" && "$(readlink -f "$src")" == "$(readlink -f "$startup_root")" && -e "$src/.agentsandbox" ]]; then
          mkdir -p "$dst/.agentsandbox"
          mount --bind "$src/.agentsandbox" "$dst/.agentsandbox"
          mount -o remount,bind,ro "$dst/.agentsandbox"
        fi
      done < "$mounts_file"
      ;;
    __start-virtiofs-inner)
      local source_dir="$2" socket_path="$3" pid_path="$4" readonly="$5" runtime_log="$6" pid=""

      rm -f "$socket_path" "$pid_path"
      if [[ "$readonly" == "1" ]]; then
        virtiofsd --socket-path "$socket_path" --shared-dir "$source_dir" --sandbox none --readonly >> "$runtime_log" 2>&1 &
      else
        virtiofsd --socket-path "$socket_path" --shared-dir "$source_dir" --sandbox none >> "$runtime_log" 2>&1 &
      fi
      pid="$!"
      printf '%s\n' "$pid" > "$pid_path"
      for pid in $(seq 1 50); do
        [[ -S "$socket_path" ]] && return 0
        sleep 0.1
      done
      die "timed out waiting for virtiofsd socket: $socket_path"
      ;;
    __opensnitch-watchdog)
      local domain_name="$2" runtime_log="$3" forward_pid_file="$4" forward_port="$5" grace_seconds="${6:-15}"
      local deadline="" forward_pid="" observed="0"

      deadline=$((SECONDS + grace_seconds))
      while :; do
        if [[ ! -r "$forward_pid_file" ]]; then
          virsh -c "$URI" destroy "$domain_name" >/dev/null 2>&1 || true
          exit 1
        fi
        forward_pid="$(<"$forward_pid_file")"
        if ! kill -0 "$forward_pid" >/dev/null 2>&1; then
          printf '%s opensnitch-forward exited\n' "$(date -Iseconds)" >> "$runtime_log"
          virsh -c "$URI" destroy "$domain_name" >/dev/null 2>&1 || true
          exit 1
        fi
        if ss -tnH state established "( sport = :${forward_port} )" | grep -q .; then
          observed="1"
        elif [[ "$observed" == "1" || "$SECONDS" -ge "$deadline" ]]; then
          printf '%s opensnitch connection lost\n' "$(date -Iseconds)" >> "$runtime_log"
          virsh -c "$URI" destroy "$domain_name" >/dev/null 2>&1 || true
          exit 1
        fi
        sleep 1
      done
      ;;
    init)
      shift || true
      if [[ "${1:-}" == "--global" ]]; then
        global_flag="1"
        shift || true
      fi
      local init_target=""

      if [[ "$global_flag" == "1" ]]; then
        init_target="${XDG_CONFIG_HOME:-$HOME/.config}/agentsandbox"
      else
        init_target="$PWD/.agentsandbox"
      fi

      install -d "$init_target"
      for cmd in flake.nix configuration.nix allowed_hosts mounts; do
        [[ ! -e "$init_target/$cmd" ]] || die "$init_target/$cmd already exists"
        install -m 644 "$TEMPLATE_DIR/$cmd" "$init_target/$cmd"
      done
      ;;
    doctor)
      eval "$("$SCRIPT_PATH" __resolve-active-config "$PWD" 2>/dev/null || true)"
      printf 'script: %s\n' "$SCRIPT_PATH"
      printf 'template: %s\n' "$TEMPLATE_DIR"
      printf 'uri: %s\n' "$URI"
      command -v nix >/dev/null 2>&1 && printf 'nix: %s\n' "$(command -v nix)" || printf 'nix: missing\n'
      command -v virsh >/dev/null 2>&1 && printf 'virsh: %s\n' "$(command -v virsh)" || printf 'virsh: missing\n'
      command -v qemu-system-x86_64 >/dev/null 2>&1 && printf 'qemu: %s\n' "$(command -v qemu-system-x86_64)" || printf 'qemu: missing\n'
      command -v virtiofsd >/dev/null 2>&1 && printf 'virtiofsd: %s\n' "$(command -v virtiofsd)" || printf 'virtiofsd: missing\n'
      command -v mitmdump >/dev/null 2>&1 && printf 'mitmdump: %s\n' "$(command -v mitmdump)" || printf 'mitmdump: missing\n'
      command -v bwrap >/dev/null 2>&1 && printf 'bwrap: %s\n' "$(command -v bwrap)" || printf 'bwrap: missing\n'
      if [[ -n "${ACTIVE_CONFIG_DIR:-}" ]]; then
        printf 'active-config: %s\n' "$ACTIVE_CONFIG_DIR"
      fi
      ;;
    build)
      eval "$("$SCRIPT_PATH" __ensure-active-config "$PWD")"
      eval "$("$SCRIPT_PATH" __resolve-instance "$STARTUP_WORKSPACE_ROOT" "$ACTIVE_CONFIG_DIR" "$DEFAULT_PROFILE")"
      eval "$("$SCRIPT_PATH" __eval-profile "$ACTIVE_CONFIG_DIR" "$PROFILE_NAME")"
      prepare "$DATA_DIR" "$STATE_DIR" "$RUNTIME_DIR" "$MACHINE_ID"
      bash "$SCRIPT_PATH" __ensure-startup-mount "$ACTIVE_CONFIG_DIR" "$STARTUP_WORKSPACE_ROOT" "$STARTUP_WORKSPACE_NAME" >/dev/null
      ensure_system "$DATA_DIR/sysroot" "$ACTIVE_CONFIG_DIR" "$NIXOS_CONFIGURATION"
      ;;
    up|"")
      [[ -n "$cmd" ]] && shift || true
      eval "$("$SCRIPT_PATH" __ensure-active-config "$PWD")"
      eval "$("$SCRIPT_PATH" __resolve-instance "$STARTUP_WORKSPACE_ROOT" "$ACTIVE_CONFIG_DIR" "$DEFAULT_PROFILE")"
      eval "$("$SCRIPT_PATH" __eval-profile "$ACTIVE_CONFIG_DIR" "$PROFILE_NAME")"
      prepare "$DATA_DIR" "$STATE_DIR" "$RUNTIME_DIR" "$MACHINE_ID"
      bash "$SCRIPT_PATH" __ensure-startup-mount "$ACTIVE_CONFIG_DIR" "$STARTUP_WORKSPACE_ROOT" "$STARTUP_WORKSPACE_NAME" >/dev/null
      [[ -n "$RUNTIME_DIR" ]] || die "XDG_RUNTIME_DIR is required"
      [[ -e "$ACTIVE_CONFIG_DIR/allowed_hosts" ]] || cp "$TEMPLATE_DIR/allowed_hosts" "$ACTIVE_CONFIG_DIR/allowed_hosts"

      if running_pid "$DOMAIN_NAME" >/dev/null; then
        if [[ -z "$cmd" ]]; then
          shift 0
          local attach_port=""
          attach_port="$(
            jq -r '.[] | select(.proto == "tcp" and .guest == 22) | .host' <<<"$PORT_FORWARDS_JSON" | head -n 1
          )"
          sandbox_exec "$attach_port" "$@"
        fi
        die "VM is already running"
      fi

      exec 9>"$RUNTIME_DIR/lock"
      flock -n 9 || die "another agentsandbox process already owns $RUNTIME_DIR/lock"

      # Log rotation block. Keep this block byte-for-byte aligned with future call sites.
      log_file="$STATE_DIR/logs/runtime.log"
      if [[ -f "$log_file" ]]; then
        size_bytes="$(stat -c %s "$log_file")"
        if (( size_bytes >= RUNTIME_LOG_ROTATE_BYTES )); then
          timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
          case "$log_file" in
            *.jsonl) archive_base="${log_file%.jsonl}-${timestamp}.jsonl" ;;
            *.log) archive_base="${log_file%.log}-${timestamp}.log" ;;
