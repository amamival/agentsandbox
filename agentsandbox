        [[ -r "$pid_file" ]] || continue
        pid="$(<"$pid_file")"
        [[ -n "$pid" ]] && kill "$pid" >/dev/null 2>&1 || true
        rm -f "$pid_file"
      done
      rm -f \
        "$RUNTIME_DIR/proxy-addon.py" \
        "$RUNTIME_DIR/virtiofs/nix.sock" \
        "$RUNTIME_DIR/virtiofs/persistent.sock"
      ;;
    allow-domain)
      shift || true
      [[ -n "${1:-}" ]] || die "usage: ${APP_NAME} allow-domain DOMAIN"
      eval "$("$SCRIPT_PATH" __resolve-active-config "$PWD")"
      local allow_host=""

      # Normalize host/glob exactly like the proxy host matcher expects.
      allow_host="$1"
      allow_host="${allow_host#http://}"
      allow_host="${allow_host#https://}"
      allow_host="${allow_host%%/*}"
      if [[ "$allow_host" == \[* ]]; then
        allow_host="${allow_host#[}"
        allow_host="${allow_host%%]*}"
      else
        allow_host="${allow_host%%:*}"
      fi
      allow_host="${allow_host,,}"
      while [[ "$allow_host" == *"." ]]; do
        allow_host="${allow_host%.}"
      done
      [[ -n "$allow_host" ]] || die "empty domain"
      [[ -e "$ACTIVE_CONFIG_DIR/allowed_hosts" ]] || cp "$TEMPLATE_DIR/allowed_hosts" "$ACTIVE_CONFIG_DIR/allowed_hosts"
      if ! grep -Fxq -- "$allow_host" "$ACTIVE_CONFIG_DIR/allowed_hosts" 2>/dev/null; then
        printf '%s\n' "$allow_host" >> "$ACTIVE_CONFIG_DIR/allowed_hosts"
      fi
      ;;
    unallow-domain)
      shift || true
      [[ -n "${1:-}" ]] || die "usage: ${APP_NAME} unallow-domain DOMAIN"
      eval "$("$SCRIPT_PATH" __resolve-active-config "$PWD")"
      local unallow_host="" unallow_tmp=""

      # Normalize host/glob exactly like the proxy host matcher expects.
      unallow_host="$1"
      unallow_host="${unallow_host#http://}"
      unallow_host="${unallow_host#https://}"
      unallow_host="${unallow_host%%/*}"
      if [[ "$unallow_host" == \[* ]]; then
        unallow_host="${unallow_host#[}"
        unallow_host="${unallow_host%%]*}"
      else
        unallow_host="${unallow_host%%:*}"
      fi
      unallow_host="${unallow_host,,}"
      while [[ "$unallow_host" == *"." ]]; do
        unallow_host="${unallow_host%.}"
      done
      [[ -e "$ACTIVE_CONFIG_DIR/allowed_hosts" ]] || cp "$TEMPLATE_DIR/allowed_hosts" "$ACTIVE_CONFIG_DIR/allowed_hosts"
      unallow_tmp="$(mktemp)"
      grep -Fxv -- "$unallow_host" "$ACTIVE_CONFIG_DIR/allowed_hosts" > "$unallow_tmp" || true
      mv "$unallow_tmp" "$ACTIVE_CONFIG_DIR/allowed_hosts"
      ;;
    mount)
      shift || true
      eval "$("$SCRIPT_PATH" __resolve-active-config "$PWD")"
      bash "$SCRIPT_PATH" __ensure-startup-mount "$ACTIVE_CONFIG_DIR" "$STARTUP_WORKSPACE_ROOT" "$STARTUP_WORKSPACE_NAME" >/dev/null
      if [[ "$#" -eq 0 ]]; then
        cat "$ACTIVE_CONFIG_DIR/mounts"
        return 0
      fi
      local mount_src="" mount_name="" helper_pid=""

      mount_src="$(readlink -f "$1")"
      mount_name="${2:-$(basename "$mount_src")}"
      [[ -e "$mount_src" ]] || die "mount source does not exist: $mount_src"
      [[ "$mount_name" != */* ]] || die "guest mount name must not contain /"
      if awk -F $'\t' -v src="$mount_src" -v name="$mount_name" '
        /^[[:space:]]*#/ || NF == 0 { next }
        $1 == src && $2 == name { exact = 1; next }
        $1 == src || $2 == name { conflict = 1 }
        END {
          if (conflict) exit 2
          if (exact) exit 0
          exit 1
        }
      ' "$ACTIVE_CONFIG_DIR/mounts"; then
        :
      elif [[ "$?" -eq 1 ]]; then
        printf '%s\t%s\n' "$mount_src" "$mount_name" >> "$ACTIVE_CONFIG_DIR/mounts"
      else
        die "mount path or guest name is already assigned"
      fi
      if eval "$("$SCRIPT_PATH" __resolve-instance "$STARTUP_WORKSPACE_ROOT" "$ACTIVE_CONFIG_DIR" "$DEFAULT_PROFILE")" \
        && [[ -r "$RUNTIME_DIR/mount-helper.pid" ]]; then
        helper_pid="$(<"$RUNTIME_DIR/mount-helper.pid")"
        if [[ -n "$helper_pid" ]] && kill -0 "$helper_pid" 2>/dev/null; then
          eval "$("$SCRIPT_PATH" __eval-profile "$ACTIVE_CONFIG_DIR" "$PROFILE_NAME")"
          mount_workspace \
            "$helper_pid" \
            "$DATA_DIR/persistent" \
            "$ACTIVE_CONFIG_DIR/mounts" \
            "$STARTUP_WORKSPACE_ROOT" \
            "$STARTUP_WORKSPACE_NAME" \
            "$MUTABLE_SANDBOX_CONFIG"
        fi
      fi
      ;;
    unmount)
      shift || true
      eval "$("$SCRIPT_PATH" __resolve-active-config "$PWD")"
      bash "$SCRIPT_PATH" __ensure-startup-mount "$ACTIVE_CONFIG_DIR" "$STARTUP_WORKSPACE_ROOT" "$STARTUP_WORKSPACE_NAME" >/dev/null
      [[ -n "${1:-}" ]] || die "usage: ${APP_NAME} unmount PATH"
      local unmount_src="" unmount_tmp="" helper_pid=""

      unmount_src="$(readlink -f "$1")"
      [[ "$unmount_src" != "$(readlink -f "$STARTUP_WORKSPACE_ROOT")" ]] || die "cannot remove the startup workspace mount"
      unmount_tmp="$(mktemp)"
      awk -F $'\t' -v src="$unmount_src" '
        /^[[:space:]]*#/ || NF == 0 { print; next }
        $1 != src { print }
      ' "$ACTIVE_CONFIG_DIR/mounts" > "$unmount_tmp"
      mv "$unmount_tmp" "$ACTIVE_CONFIG_DIR/mounts"
      if eval "$("$SCRIPT_PATH" __resolve-instance "$STARTUP_WORKSPACE_ROOT" "$ACTIVE_CONFIG_DIR" "$DEFAULT_PROFILE")" \
        && [[ -r "$RUNTIME_DIR/mount-helper.pid" ]]; then
        helper_pid="$(<"$RUNTIME_DIR/mount-helper.pid")"
        if [[ -n "$helper_pid" ]] && kill -0 "$helper_pid" 2>/dev/null; then
          eval "$("$SCRIPT_PATH" __eval-profile "$ACTIVE_CONFIG_DIR" "$PROFILE_NAME")"
          unmount_workspace \
            "$helper_pid" \
            "$DATA_DIR/persistent" \
            "$ACTIVE_CONFIG_DIR/mounts" \
            "$STARTUP_WORKSPACE_ROOT" \
            "$STARTUP_WORKSPACE_NAME" \
            "$MUTABLE_SANDBOX_CONFIG"
        fi
      fi
      ;;
    proxy-logs)
      shift || true
      eval "$("$SCRIPT_PATH" __resolve-active-config "$PWD")"
      eval "$("$SCRIPT_PATH" __resolve-instance "$STARTUP_WORKSPACE_ROOT" "$ACTIVE_CONFIG_DIR" "$DEFAULT_PROFILE")"
      install -d "$STATE_DIR/logs"
      touch "$STATE_DIR/logs/requests.jsonl"
      for request_log in "$STATE_DIR"/logs/requests-*.jsonl.zst; do
        [[ -e "$request_log" ]] || continue
        zstd -dc -- "$request_log"
      done
      for request_log in "$STATE_DIR"/logs/requests-*.jsonl; do
        [[ -e "$request_log" && "$request_log" != "$STATE_DIR/logs/requests.jsonl" ]] || continue
        [[ ! -e "${request_log}.zst" ]] || continue
        cat -- "$request_log"
      done
      exec tail -n +1 -F "$STATE_DIR/logs/requests.jsonl"
      ;;
    *)
      die "unknown subcommand: ${cmd:-<empty>}"
      ;;
  esac
}

main "$@"
