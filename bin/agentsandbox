#!/usr/bin/env bash
set -euxo pipefail

AS_NIXOS_ATTR="${AS_NIXOS_ATTR:-default}"
AS_LOG_ROTATE_BYTES="${AS_LOG_ROTATE_BYTES:-$(( 50 * 1024 * 1024 ))}"
export LIBVIRT_DEFAULT_URI="${LIBVIRT_DEFAULT_URI:-qemu:///session}"

APP_NAME="agentsandbox"
VERSION="0.0.0-dev"

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
TEMPLATE_DIR="$(dirname -- "$SCRIPT_PATH")/../share/$APP_NAME/template"
DATA_ROOT="${XDG_DATA_HOME:-$HOME/.local/share}/$APP_NAME"
STATE_ROOT="${XDG_STATE_HOME:-$HOME/.local/state}/$APP_NAME"
(( UID == 0 )) && : "${XDG_RUNTIME_DIR:=/run}" || : "${XDG_RUNTIME_DIR:=/run/user/$UID}"
RUNTIME_ROOT="$XDG_RUNTIME_DIR/$APP_NAME"

function die() { echo "$APP_NAME: $*" >&2; exit 1; }

function usage() {
  cat <<EOF
usage: ${APP_NAME} [help|version|doctor|init|build|up|down|kill|pause|unpause|destroy|ps|ssh|exec|logs|stats|wait]
                    [mount|unmount|port|allow-domain|unallow-domain|proxy-logs|verify]

  help                Show help
  version             Show version
  doctor              Show diagnostics

  init                Create .agentsandbox/ and copy the initial template files
  build               Build the selected guest system into the instance sysroot
  up                  Rebuild and start a VM; fails if it is already running
  down                Tear down the VM gracefully
  kill                Forcibly stop the VM
  pause               Pause a running VM
  unpause             Resume a paused VM
  destroy             Delete the guest system while preserving persistent data

  ps                  Show status of the selected VM
  ssh                 Connect to a running VM
  exec                Execute a command in a running VM, or attach if omitted
  logs                Show guest journal logs
  stats               Show libvirt domain statistics
  wait                Wait for the selected VM to stop

  mount               Add a mount now and on future starts, or show current mounts
  unmount             Remove a mount now and on future starts

  port                Print the host port for a published guest port
  allow-domain        Add a domain or glob to allowed_hosts
  unallow-domain      Remove a domain or glob from allowed_hosts
  proxy-logs          Follow request logs
  verify              Verify and repair build
EOF
}

# Run $@ in a new user NS as root (via --map-root-user); $1 is wd, rest is the command.
function nssudo() {
  unshare --map-auto --map-root-user --wd "$@"
}

# Create the minimal set of per-instance host dirs that must exist before sysroot build, virtiofsd, or log writers touch them.
function prepare() {
  local INSTANCE_ID="$1"
  install -d "$DATA_ROOT/$INSTANCE_ID/sysroot" "$STATE_ROOT/$INSTANCE_ID/logs" "$RUNTIME_ROOT/$INSTANCE_ID/virtiofs"
}

# Download nixos/nix image from Docker Hub.
function fetch_nixos_dockerhub() {
  local SYSROOT="$1"
  local REPO=nixos/nix TAG=latest ARCH=amd64 OS=linux REGISTRY_ENDPOINT="https://registry-1.docker.io/v2"
  TOKEN="$(curl "https://auth.docker.io/token?service=registry.docker.io&scope=repository:$REPO:pull" | jq -r .token)"
  echo "TOKEN=$TOKEN"
  MANIFESTS="$(curl -H "Authorization: Bearer $TOKEN" "$REGISTRY_ENDPOINT/$REPO/manifests/$TAG")"
  echo "MANIFESTS=$MANIFESTS"
  MANIFEST_DIGEST="$(jq -r ".manifests[] | select(.platform.architecture == \"$ARCH\" and .platform.os == \"$OS\") | .digest" <<<"$MANIFESTS")"
  echo "MANIFEST_DIGEST=$MANIFEST_DIGEST"
  MANIFEST="$(curl -H "Authorization: Bearer $TOKEN" "$REGISTRY_ENDPOINT/$REPO/manifests/$MANIFEST_DIGEST")"
  echo "MANIFEST=$MANIFEST"
  BLOBSUMS="$(jq -r '.layers[].digest' <<<"$MANIFEST")"
  echo "BLOBSUMS=$BLOBSUMS"
  while read -r BLOBSUM; do
    curl -IH "Authorization: Bearer $TOKEN" "$REGISTRY_ENDPOINT/$REPO/blobs/$BLOBSUM" # Docker hub requires this.
    curl -LH "Authorization: Bearer $TOKEN" "$REGISTRY_ENDPOINT/$REPO/blobs/$BLOBSUM" | nssudo "$SYSROOT" tar zxf -
  done <<<"$BLOBSUMS"
}

# Build NixOS system in sysroot.
function install_nixos() {
  local SYSROOT="$1" FLAKE_DIR="$2" FLAKE_ATTR="$3"
  nssudo "$SYSROOT" cp -aT "$FLAKE_DIR" "$SYSROOT/etc/nixos"
  nssudo "$SYSROOT" rm -f "$SYSROOT/nix/var/nix/profiles/system"
  # Python's _multiprocessing.SemLock expects a writable 1777 /dev/shm.
  nssudo "$SYSROOT" bwrap --bind "$SYSROOT" / --ro-bind /etc/resolv.conf /etc/resolv.conf \
    --proc /proc --dev /dev --perms 1777 --tmpfs /dev/shm \
    /nix/var/nix/profiles/default/bin/nix --extra-experimental-features 'nix-command flakes' \
      build "/etc/nixos#nixosConfigurations.$FLAKE_ATTR.config.system.build.toplevel" \
      --out-link /nix/var/nix/profiles/system
}

# Populate sysroot on first run, rebuild NixOS from the flake, and print the toplevel store path for caller consumption.
function ensure_system() {
  local SYSROOT="$1" FLAKE_DIR="$2" FLAKE_ATTR="$3"
  [[ -d "$SYSROOT/nix/store" ]] || fetch_nixos_dockerhub "$SYSROOT"
  install_nixos "$SYSROOT" "$FLAKE_DIR" "$FLAKE_ATTR"
  readlink -f "$SYSROOT/nix/var/nix/profiles/system"
}

# Return success when the libvirt domain is in any of the given states ($2..). Caller must pass at least one state.
function is_domstate() {
  printf '%s\n' "${@:2}" | grep -Fxq -- "$(virsh domstate "$1" 2>/dev/null || true)"
}

# Exit the script unless the domain is currently running.
function require_running() { is_domstate "$1" running || die "VM is not running"; }

# $1=instance RUNTIME_DIR. Kills mount-helper/proxy/opensnitch/virtiofsd sidecars; removes pid files and proxy/sock paths.
function cleanup_runtime_helpers() {
  local RUNTIME_DIR="$1" pid_file="" pid=""

  for pid_file in \
    "$RUNTIME_DIR/mount-helper.pid" \
    "$RUNTIME_DIR/proxy.pid" \
    "$RUNTIME_DIR/opensnitch-forward.pid" \
    "$RUNTIME_DIR/opensnitch-watchdog.pid" \
    "$RUNTIME_DIR/virtiofs/nix.pid" \
    "$RUNTIME_DIR/virtiofs/persistent.pid"
  do
    [[ -r "$pid_file" ]] || continue
    pid="$(<"$pid_file")"
    [[ -n "$pid" ]] && kill "$pid" >/dev/null 2>&1 || true
    rm -f "$pid_file"
  done
  rm -f \
    "$RUNTIME_DIR/proxy-addon.py" \
    "$RUNTIME_DIR/virtiofs/nix.sock" \
    "$RUNTIME_DIR/virtiofs/persistent.sock"
}

# Open an SSH session into the running guest VM.
function guest_ssh() {
  local SSH_USER="$1" SSH_PORT="$2"
  exec ssh "$SSH_USER@127.0.0.1" -p "$SSH_PORT" -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null "${@:3}"
}

# Attach to the guest virtio-console as emergency fallback when SSH is down.
function guest_console() { exec virsh console --force "$1"; }

function mount_workspace() {
  local helper_pid="$1" persistent_dir="$2" mounts_file="$3" flake_dir="$4" mutable="$5"

  if [[ -n "$helper_pid" ]] && kill -0 "$helper_pid" 2>/dev/null; then
    nsenter -t "$helper_pid" -m -- bash "$SCRIPT_PATH" __sync-mounts-inner \
      "$persistent_dir" "$mounts_file" "$flake_dir" "$mutable"
  fi
}

function unmount_workspace() {
  local helper_pid="$1" persistent_dir="$2" mounts_file="$3" flake_dir="$4" mutable="$5"

  if [[ -n "$helper_pid" ]] && kill -0 "$helper_pid" 2>/dev/null; then
    nsenter -t "$helper_pid" -m -- bash "$SCRIPT_PATH" __sync-mounts-inner \
      "$persistent_dir" "$mounts_file" "$flake_dir" "$mutable"
  fi
}

# $1 = portForwards JSON; $2 = guest port; $3 = proto (default tcp). Prints matching host port.
function host_port_for_guest() {
  local json="${1:?}" want_guest="${2:?}" want_proto="${3:-tcp}"
  jq -r --argjson g "$want_guest" --arg p "$want_proto" '
    [.[] | select(.proto == $p)]
    | .[]
    | . as $e
    | ($e.guest) as $to
    | ($e.host | if type == "number" then {start: ., end: .} else . end) as $r
    | select($g >= $to and $g <= $to + ($r.end - $r.start))
    | ($r.start + ($g - $to))
  ' <<<"$json" | head -n 1
}

# Walk up from $1 to find .agentsandbox/flake.nix, else fall back to global config dir, auto-initializing it when absent. Echoes the resolved flake dir.
function get_or_create_flake_dir() {
  local d; d="$(readlink -f "$1")"
  while :; do
    [[ -f "$d/.agentsandbox/flake.nix" ]] && { echo "$d/.agentsandbox"; return; }
    [[ "$d" == / ]] && break
    d="$(dirname "$d")"
  done
  d="${XDG_CONFIG_HOME:-$HOME/.config}/agentsandbox"
  [[ -f "$d/flake.nix" ]] || bash "$SCRIPT_PATH" init --global
  echo "$d"
}

# Deterministically derive the per-profile instance id (dirname-profile-machineid), reusing any DATA_ROOT entry whose machine-id suffix matches. Echoes the instance id.
function get_or_create_instance_id() {
  local FLAKE_DIR="$1" PROFILE_NAME="$2" DIRNAME PREFIX_FILE="$1/machine-prefix" MACHINE_ID MATCH=()
  if [[ "$FLAKE_DIR" == */.agentsandbox ]]; then
    DIRNAME="$(basename "$(dirname "$FLAKE_DIR")")"
  else
    DIRNAME="$APP_NAME"
  fi
  [[ -f "$PREFIX_FILE" ]] || head -c 12 /dev/urandom | od -An -tx1 -v | tr -d ' \n' > "$PREFIX_FILE"
  MACHINE_ID="$(<"$PREFIX_FILE")$(printf '%s' "$PROFILE_NAME" | sha256sum | cut -c1-8)"
  shopt -s nullglob; MATCH=("$DATA_ROOT"/*-"$MACHINE_ID"); shopt -u nullglob
  basename "${MATCH[0]:-$DATA_ROOT/$DIRNAME-$PROFILE_NAME-$MACHINE_ID}"
}

function main() {
  local cmd="${1:-}"
  case "$cmd" in
    help|-h|--help) usage;;
    version) echo "$VERSION";;
    __get_or_create_flake_dir) get_or_create_flake_dir "${2:-$PWD}";;
    __get_or_create_instance_id) get_or_create_instance_id "$2" "$3";;
    __mount-helper)
      local persistent_dir="$2" runtime_log="$3"

      mount --make-rprivate /
      mkdir -p "$persistent_dir/home/vscode" "$persistent_dir/workspace"
      printf '%s mount-helper ready %s\n' "$(date -Iseconds)" "$persistent_dir" >> "$runtime_log"
      exec sleep infinity
      ;;
    __sync-mounts-inner)
      local persistent_dir="$2" mounts_file="$3" flake_dir="$4" mutable="$5"
      local mountinfo_line="" mountpoint_path="" src="" guest_name="" dst="" project_root=""

      [[ "$flake_dir" == */.agentsandbox ]] && project_root="$(readlink -f "$(dirname "$flake_dir")")"
      mkdir -p "$persistent_dir/home/vscode" "$persistent_dir/workspace"
      while read -r mountinfo_line; do
        [[ -n "$mountinfo_line" ]] || continue
        mountpoint_path="${mountinfo_line%% *}"
        if mountpoint -q "$mountpoint_path"; then
          umount "$mountpoint_path" >/dev/null 2>&1 || true
        fi
      done < <(
        awk -v root="$persistent_dir/workspace" '$5 ~ ("^" root "(/|$)") { print $5 }' /proc/self/mountinfo | sort -r
      )

      while IFS=$'\t' read -r src guest_name; do
        [[ -n "${src:-}" ]] || continue
        [[ "${src:0:1}" == "#" ]] && continue
        [[ -n "${guest_name:-}" ]] || die "invalid mounts entry: ${src}"
        [[ "$guest_name" != */* ]] || die "guest mount name must not contain /: ${guest_name}"
        [[ -e "$src" ]] || die "mount source does not exist: ${src}"
        dst="$persistent_dir/workspace/$guest_name"

        mkdir -p "$dst"
        mount --rbind "$src" "$dst"
        if [[ "$mutable" == "false" && -n "$project_root" && "$(readlink -f "$src")" == "$project_root" && -e "$src/.agentsandbox" ]]; then
          mkdir -p "$dst/.agentsandbox"
          mount --bind "$src/.agentsandbox" "$dst/.agentsandbox"
          mount -o remount,bind,ro "$dst/.agentsandbox"
        fi
      done < "$mounts_file"
      ;;
    __start-virtiofs-inner)
      local source_dir="$2" socket_path="$3" pid_path="$4" readonly="$5" runtime_log="$6" pid=""

      rm -f "$socket_path" "$pid_path"
      if [[ "$readonly" == "1" ]]; then
        virtiofsd --socket-path "$socket_path" --shared-dir "$source_dir" --sandbox none --readonly >> "$runtime_log" 2>&1 &
      else
        virtiofsd --socket-path "$socket_path" --shared-dir "$source_dir" --sandbox none >> "$runtime_log" 2>&1 &
      fi
      pid="$!"
      printf '%s\n' "$pid" > "$pid_path"
      for pid in $(seq 1 50); do
        [[ -S "$socket_path" ]] && return 0
        sleep 0.1
      done
      die "timed out waiting for virtiofsd socket: $socket_path"
      ;;
    __opensnitch-watchdog)
      local domain_name="$2" runtime_log="$3" forward_pid_file="$4" forward_port="$5" grace_seconds="${6:-15}"
      local deadline="" forward_pid="" observed="0"

      deadline=$((SECONDS + grace_seconds))
      while :; do
        if [[ ! -r "$forward_pid_file" ]]; then
          virsh destroy "$domain_name" >/dev/null 2>&1 || true
          exit 1
        fi
        forward_pid="$(<"$forward_pid_file")"
        if ! kill -0 "$forward_pid" >/dev/null 2>&1; then
          printf '%s opensnitch-forward exited\n' "$(date -Iseconds)" >> "$runtime_log"
          virsh destroy "$domain_name" >/dev/null 2>&1 || true
          exit 1
        fi
        if ss -tnH state established "( sport = :${forward_port} )" | grep -q .; then
          observed="1"
        elif [[ "$observed" == "1" || "$SECONDS" -ge "$deadline" ]]; then
          printf '%s opensnitch connection lost\n' "$(date -Iseconds)" >> "$runtime_log"
          virsh destroy "$domain_name" >/dev/null 2>&1 || true
          exit 1
        fi
        sleep 1
      done
      ;;
    init)
      local INIT_TARGET="$PWD/.agentsandbox" CWD
      [[ "${2:-}" == "--global" ]] && INIT_TARGET="${XDG_CONFIG_HOME:-$HOME/.config}/agentsandbox"
      [[ ! -e "$INIT_TARGET" ]] || die "$INIT_TARGET already exists"
      cp -aT "$TEMPLATE_DIR" "$INIT_TARGET"
      CWD="$(readlink -f "$PWD")"
      printf '%s\t%s\n' "$CWD" "$(basename "$CWD")" >>"$INIT_TARGET/mounts"
      ;;
    doctor)
      local CONFIG_SCOPE="" INSTANCE_ID=""
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD" 2>/dev/null || true)"
      printf 'script: %s\n' "$SCRIPT_PATH"
      printf 'template: %s\n' "$TEMPLATE_DIR"
      printf 'libvirt-uri: %s\n' "$LIBVIRT_DEFAULT_URI"
      printf 'data-root: %s\n' "$DATA_ROOT"
      printf 'state-root: %s\n' "$STATE_ROOT"
      printf 'runtime-root: %s\n' "${RUNTIME_ROOT:-}"
      printf 'profile: %s\n' "$AS_NIXOS_ATTR"
      command -v nix >/dev/null 2>&1 && printf 'nix: %s\n' "$(command -v nix)" || printf 'nix: missing\n'
      command -v virsh >/dev/null 2>&1 && printf 'virsh: %s\n' "$(command -v virsh)" || printf 'virsh: missing\n'
      command -v qemu-system-x86_64 >/dev/null 2>&1 && printf 'qemu: %s\n' "$(command -v qemu-system-x86_64)" || printf 'qemu: missing\n'
      command -v virtiofsd >/dev/null 2>&1 && printf 'virtiofsd: %s\n' "$(command -v virtiofsd)" || printf 'virtiofsd: missing\n'
      command -v mitmdump >/dev/null 2>&1 && printf 'mitmdump: %s\n' "$(command -v mitmdump)" || printf 'mitmdump: missing\n'
      command -v bwrap >/dev/null 2>&1 && printf 'bwrap: %s\n' "$(command -v bwrap)" || printf 'bwrap: missing\n'
      command -v jq >/dev/null 2>&1 && printf 'jq: %s\n' "$(command -v jq)" || printf 'jq: missing\n'
      command -v curl >/dev/null 2>&1 && printf 'curl: %s\n' "$(command -v curl)" || printf 'curl: missing\n'
      command -v zstd >/dev/null 2>&1 && printf 'zstd: %s\n' "$(command -v zstd)" || printf 'zstd: missing\n'
      command -v socat >/dev/null 2>&1 && printf 'socat: %s\n' "$(command -v socat)" || printf 'socat: missing\n'
      if [[ -n "${FLAKE_DIR:-}" ]]; then
        printf 'active-config: %s\n' "$FLAKE_DIR"
        if [[ "$FLAKE_DIR" == */.agentsandbox ]]; then
          CONFIG_SCOPE=local
        else
          CONFIG_SCOPE=global
        fi
        printf 'config-scope: %s\n' "$CONFIG_SCOPE"
        INSTANCE_ID="$(get_or_create_instance_id "$FLAKE_DIR" "$AS_NIXOS_ATTR" 2>/dev/null || true)"
        if [[ -n "${INSTANCE_ID:-}" ]]; then
          printf 'instance-id: %s\n' "$INSTANCE_ID"
          printf 'machine-id: %s\n' "${INSTANCE_ID: -20}"
          printf 'data-dir: %s\n' "$DATA_ROOT/$INSTANCE_ID"
          printf 'state-dir: %s\n' "$STATE_ROOT/$INSTANCE_ID"
          printf 'runtime-dir: %s\n' "$RUNTIME_ROOT/$INSTANCE_ID"
        fi
      fi
      ;;
    build)
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      INSTANCE_ID="$(get_or_create_instance_id "$FLAKE_DIR" "$AS_NIXOS_ATTR")"
      prepare "$INSTANCE_ID"
      ensure_system "$DATA_ROOT/$INSTANCE_ID/sysroot" "$FLAKE_DIR" "$AS_NIXOS_ATTR"
      ;;
    up|"")
      [[ -n "$cmd" ]] && shift
      local DETACH=0 NC=""
      [[ "${1:-}" == "-d" ]] && { DETACH=1; }
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      INSTANCE_ID="$(get_or_create_instance_id "$FLAKE_DIR" "$AS_NIXOS_ATTR")"
      MACHINE_ID="${INSTANCE_ID: -20}"
      DOMAIN_UUID="${MACHINE_ID:0:8}-${MACHINE_ID:8:4}-${MACHINE_ID:12:4}-${MACHINE_ID:16:4}-${MACHINE_ID:20:12}"
      DATA_DIR="$DATA_ROOT/$INSTANCE_ID"
      STATE_DIR="$STATE_ROOT/$INSTANCE_ID"
      RUNTIME_DIR="$RUNTIME_ROOT/$INSTANCE_ID"
      NC="${FLAKE_DIR}#nixosConfigurations.${AS_NIXOS_ATTR}.config"
      FLAKE_ATTR="$AS_NIXOS_ATTR"
      PROFILE_NAME="$AS_NIXOS_ATTR"
      MUTABLE_SANDBOX_CONFIG="$(jq -r . <<<"$(nix eval --json "${NC}.agentsandbox.mutableSandboxConfig")")"
      MEMORY_MIB="$(jq -r . <<<"$(nix eval --json "${NC}.agentsandbox.memoryMiB")")"
      VCPUS="$(jq -r . <<<"$(nix eval --json "${NC}.agentsandbox.vcpus")")"
      PORT_FORWARDS_JSON="$(nix eval --json "${NC}.agentsandbox.portForwards")"
      # OPENSNITCH_ENABLED="$(jq -r . <<<"$(nix eval --json "${NC}.services.opensnitch.enable")")"
      # OPENSNITCH_ADDRESS="$(nix eval --raw "${NC}.services.opensnitch.settings.Server.Address")"
      if is_domstate "$INSTANCE_ID" running; then
        (( DETACH )) && die "VM is already running"
        guest_ssh root "$(host_port_for_guest "$PORT_FORWARDS_JSON" 22 tcp)"
        return 0
      fi
      prepare "$INSTANCE_ID"
      # [[ -e "$FLAKE_DIR/allowed_hosts" ]] || cp "$TEMPLATE_DIR/allowed_hosts" "$FLAKE_DIR/allowed_hosts"

      exec 9>"$RUNTIME_DIR/lock"
      flock -n 9 || die "another agentsandbox process already owns $RUNTIME_DIR/lock"

      # # Log rotation block. Keep this block byte-for-byte aligned with future call sites.
      # log_file="$STATE_DIR/logs/runtime.log"
      # if [[ -f "$log_file" ]]; then
      #   size_bytes="$(stat -c %s "$log_file")"
      #   if (( size_bytes >= AS_LOG_ROTATE_BYTES )); then
      #     timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
      #     case "$log_file" in
      #       *.jsonl) archive_base="${log_file%.jsonl}-${timestamp}.jsonl" ;;
      #       *.log) archive_base="${log_file%.log}-${timestamp}.log" ;;
      #       *) archive_base="${log_file}-${timestamp}" ;;
      #     esac
      #     mv "$log_file" "$archive_base"
      #     zstd -fq --rm "$archive_base"
      #   fi
      # fi
      # touch "$log_file"

      # Log rotation block. Keep this block byte-for-byte aligned with future call sites.
      # log_file="$STATE_DIR/logs/requests.jsonl"
      # if [[ -f "$log_file" ]]; then
      #   size_bytes="$(stat -c %s "$log_file")"
      #   if (( size_bytes >= AS_LOG_ROTATE_BYTES )); then
      #     timestamp="$(date -u +%Y%m%dT%H%M%SZ)"
      #     case "$log_file" in
      #       *.jsonl) archive_base="${log_file%.jsonl}-${timestamp}.jsonl" ;;
      #       *.log) archive_base="${log_file%.log}-${timestamp}.log" ;;
      #       *) archive_base="${log_file}-${timestamp}" ;;
      #     esac
      #     mv "$log_file" "$archive_base"
      #     zstd -fq --rm "$archive_base"
      #   fi
      # fi
      # touch "$log_file"

      # cleanup_runtime_helpers "$RUNTIME_DIR"

      local toplevel_host="" helper_pid="" xml_path="" kernel_params=""
      # local ssh_port="" opensnitch_port="" github_token="" proxy_addon="" proxy_confdir=""
      # local proxy_pid="" log_file="" size_bytes="" timestamp="" archive_base="" pid_file="" pid=""

      toplevel_host="$(ensure_system "$DATA_DIR/sysroot" "$FLAKE_DIR" "$FLAKE_ATTR")"
      # github_token="${AGENTSANDBOX_GITHUB_TOKEN:-${GH_TOKEN:-${GITHUB_TOKEN:-}}}"
      # proxy_addon="$RUNTIME_DIR/proxy-addon.py"
      # proxy_confdir="$DATA_DIR/persistent/proxy/mitmproxy"
      # rm -f "$proxy_addon" "$RUNTIME_DIR/proxy.pid"
      # install -d "$proxy_confdir"
      # [[ -f "$TEMPLATE_DIR/../mitm-proxy-ca.key" && -f "$TEMPLATE_DIR/../mitm-proxy-ca.pem" ]] \
      #   || die "missing mitm-proxy-ca.{key,pem} next to $TEMPLATE_DIR"
      # cat "$TEMPLATE_DIR/../mitm-proxy-ca.key" "$TEMPLATE_DIR/../mitm-proxy-ca.pem" >"$proxy_confdir/mitmproxy-ca.pem"
      # chmod 600 "$proxy_confdir/mitmproxy-ca.pem"
      # cp -f "$TEMPLATE_DIR/../mitm-proxy-ca.pem" "$proxy_confdir/mitmproxy-ca-cert.pem"
      # rm -f \
      #   "$proxy_confdir/mitmproxy-ca-cert.cer" \
      #   "$proxy_confdir/mitmproxy-ca-cert.p12" \
      #   "$proxy_confdir/mitmproxy-ca.p12" \
      #   "$proxy_confdir/mitmproxy-dhparam.pem"

      # Proxy sidecar addon. Keep this block byte-for-byte aligned with future call sites.
#       cat >"$proxy_addon" <<'EOF'
# from __future__ import annotations

# import fnmatch
# import json
# import os
# from datetime import datetime, timezone

# from mitmproxy import http

# ALLOWED_HOSTS_FILE = os.environ["AGENTSANDBOX_ALLOWED_HOSTS"]
# REQUEST_LOG = os.environ["AGENTSANDBOX_REQUEST_LOG"]
# GITHUB_TOKEN = os.environ.get("AGENTSANDBOX_GITHUB_TOKEN", "")


# def normalize_host(value: str) -> str:
#     host = value.strip().lower().rstrip(".")
#     if host.startswith("[") and "]" in host:
#         host = host[1 : host.index("]")]
#     elif ":" in host:
#         host = host.split(":", 1)[0]
#     return host


# class AgentSandboxProxy:
#     def __init__(self) -> None:
#         self.allowed_hosts = []
#         self.allowed_hosts_mtime = None

#     def load_allowed_hosts(self) -> None:
#         try:
#             stat_result = os.stat(ALLOWED_HOSTS_FILE)
#         except FileNotFoundError:
#             self.allowed_hosts = []
#             self.allowed_hosts_mtime = None
#             return
#         if self.allowed_hosts_mtime == stat_result.st_mtime_ns:
#             return
#         loaded = []
#         with open(ALLOWED_HOSTS_FILE, "r", encoding="utf-8") as handle:
#             for raw_line in handle:
#                 line = raw_line.strip().lower()
#                 if not line or line.startswith("#"):
#                     continue
