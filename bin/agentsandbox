#       [[ "$proxy_pid" != 50 ]] || die "timed out waiting for proxy on port ${PROXY_PORT}"
      unshare --mount --fork --pid -- bash "$SCRIPT_PATH" __mount-helper "$DATA_DIR/persistent" "$STATE_DIR/logs/runtime.log" &
      helper_pid="$!"
      printf '%s\n' "$helper_pid" > "$RUNTIME_DIR/mount-helper.pid"
      mount_workspace \
        "$helper_pid" \
        "$DATA_DIR/persistent" \
        "$FLAKE_DIR/mounts" \
        "$FLAKE_DIR" \
        "$MUTABLE_SANDBOX_CONFIG"

      nsenter -t "$helper_pid" -m -- bash "$SCRIPT_PATH" __start-virtiofs-inner \
        "$DATA_DIR/sysroot/nix" \
        "$RUNTIME_DIR/virtiofs/nix.sock" \
        "$RUNTIME_DIR/virtiofs/nix.pid" \
        0 \
        "$STATE_DIR/logs/runtime.log"
      nsenter -t "$helper_pid" -m -- bash "$SCRIPT_PATH" __start-virtiofs-inner \
        "$DATA_DIR/persistent" \
        "$RUNTIME_DIR/virtiofs/persistent.sock" \
        "$RUNTIME_DIR/virtiofs/persistent.pid" \
        0 \
        "$STATE_DIR/logs/runtime.log"

      # if [[ "$OPENSNITCH_ENABLED" == "true" ]]; then
      #   opensnitch_port="${OPENSNITCH_ADDRESS##*:}"
      #   socat "TCP-LISTEN:${opensnitch_port},bind=0.0.0.0,reuseaddr,fork" "TCP:127.0.0.1:50051" \
      #     >>"$STATE_DIR/logs/runtime.log" 2>&1 &
      #   printf '%s\n' "$!" > "$RUNTIME_DIR/opensnitch-forward.pid"
      # fi

      kernel_params="$(tr '\n' ' ' < "$toplevel_host/kernel-params" | sed -e 's/[[:space:]]*$//')"
      xml_path="$(
        CONFIG_DIR="$FLAKE_DIR" \
        PROFILE_NAME="$PROFILE_NAME" \
        INSTANCE_ID="$INSTANCE_ID" \
        DOMAIN_UUID="$DOMAIN_UUID" \
        MACHINE_ID="$MACHINE_ID" \
        TOPLEVEL_HOST="$toplevel_host" \
        KERNEL_PARAMS="$kernel_params" \
        SYSROOT_NIX_DIR="$DATA_DIR/sysroot/nix" \
        PERSISTENT_DIR="$DATA_DIR/persistent" \
        RUNTIME_DIR="$RUNTIME_DIR" \
        MEMORY_MIB_JSON="$(printf '%s' "$MEMORY_MIB")" \
        VCPUS_JSON="$(printf '%s' "$VCPUS")" \
        PORT_FORWARDS_JSON="$PORT_FORWARDS_JSON" \
        nix build --no-link --print-out-paths --impure --expr '
          let
            flake = builtins.getFlake (builtins.getEnv "CONFIG_DIR");
            pkgs = import flake.inputs.nixpkgs { system = builtins.currentSystem; config.allowUnfree = true; };
            cfg = (builtins.getAttr (builtins.getEnv "PROFILE_NAME") flake.outputs.nixosConfigurations).config.agentsandbox;
          in
            cfg.libvirtXml {
              inherit pkgs;
              name = builtins.getEnv "INSTANCE_ID";
              uuid = builtins.getEnv "DOMAIN_UUID";
              machineId = builtins.getEnv "MACHINE_ID";
              toplevel = builtins.getEnv "TOPLEVEL_HOST";
              kernelParams = builtins.getEnv "KERNEL_PARAMS";
              sysrootNixDir = builtins.getEnv "SYSROOT_NIX_DIR";
              persistentDir = builtins.getEnv "PERSISTENT_DIR";
              runtimeDir = builtins.getEnv "RUNTIME_DIR";
              memoryMiB = builtins.fromJSON (builtins.getEnv "MEMORY_MIB_JSON");
              vcpus = builtins.fromJSON (builtins.getEnv "VCPUS_JSON");
              portForwards = builtins.fromJSON (builtins.getEnv "PORT_FORWARDS_JSON");
            }
        '
      )"

      virsh create "$xml_path" >/dev/null
      printf '%s\n' "$INSTANCE_ID"

      # if [[ "$OPENSNITCH_ENABLED" == "true" ]]; then
      #   bash "$SCRIPT_PATH" __opensnitch-watchdog \
      #     "$INSTANCE_ID" \
      #     "$STATE_DIR/logs/runtime.log" \
      #     "$RUNTIME_DIR/opensnitch-forward.pid" \
      #     "$opensnitch_port" \
      #     15 &
      #   printf '%s\n' "$!" > "$RUNTIME_DIR/opensnitch-watchdog.pid"
      # fi

      # (( DETACH )) && return 0
      # ssh_port="$(host_port_for_guest "$PORT_FORWARDS_JSON" 22 tcp)"
      # for helper_pid in $(seq 1 90); do
      #   ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ConnectTimeout=2 \
      #     -p "$ssh_port" root@127.0.0.1 true >/dev/null 2>&1 && { guest_ssh root "$ssh_port"; return 0; }
      #   sleep 2
      # done
      # die "guest did not become reachable over ssh"
      ;;
    down)
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      INSTANCE_ID="$(get_or_create_instance_id "$FLAKE_DIR" "$AS_NIXOS_ATTR")"
      require_running "$INSTANCE_ID"
      virsh shutdown "$INSTANCE_ID"
      ;;
    kill)
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      INSTANCE_ID="$(get_or_create_instance_id "$FLAKE_DIR" "$AS_NIXOS_ATTR")"
      RUNTIME_DIR="$RUNTIME_ROOT/$INSTANCE_ID"
      require_running "$INSTANCE_ID"
      virsh destroy "$INSTANCE_ID"
      cleanup_runtime_helpers "$RUNTIME_DIR"
      ;;
    pause)
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      INSTANCE_ID="$(get_or_create_instance_id "$FLAKE_DIR" "$AS_NIXOS_ATTR")"
      require_running "$INSTANCE_ID"
      virsh suspend "$INSTANCE_ID"
      ;;
    unpause)
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      INSTANCE_ID="$(get_or_create_instance_id "$FLAKE_DIR" "$AS_NIXOS_ATTR")"
      require_running "$INSTANCE_ID"
      virsh resume "$INSTANCE_ID"
      ;;
    destroy)
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      INSTANCE_ID="$(get_or_create_instance_id "$FLAKE_DIR" "$AS_NIXOS_ATTR")"
      DATA_DIR="$DATA_ROOT/$INSTANCE_ID"
      RUNTIME_DIR="$RUNTIME_ROOT/$INSTANCE_ID"
      virsh destroy "$INSTANCE_ID" || true
      cleanup_runtime_helpers "$RUNTIME_DIR"
      rm -rf "$DATA_DIR/sysroot"
      ;;
    ps)
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      INSTANCE_ID="$(get_or_create_instance_id "$FLAKE_DIR" "$AS_NIXOS_ATTR")"
      MACHINE_ID="${INSTANCE_ID: -20}"
      local domain_state=""
      domain_state="$(virsh domstate "$INSTANCE_ID" 2>/dev/null || printf 'stopped')"
      printf '%s\t%s\t%s\n' "$MACHINE_ID" "$INSTANCE_ID" "$domain_state"
      ;;
    port)
      shift
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      PORT_FORWARDS_JSON="$(nix eval --json \
        "${FLAKE_DIR}#nixosConfigurations.${AS_NIXOS_ATTR}.config.agentsandbox.portForwards")"
      local guest_port="${1:-22}" guest_proto="${2:-tcp}"
      host_port_for_guest "$PORT_FORWARDS_JSON" "$guest_port" "$guest_proto"
      ;;
    ssh|exec)
      shift
      local ssh_user=vscode ssh_port=""
      [[ "$cmd" == exec ]] && ssh_user=root
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      INSTANCE_ID="$(get_or_create_instance_id "$FLAKE_DIR" "$AS_NIXOS_ATTR")"
      PORT_FORWARDS_JSON="$(nix eval --json \
        "${FLAKE_DIR}#nixosConfigurations.${AS_NIXOS_ATTR}.config.agentsandbox.portForwards")"
      require_running "$INSTANCE_ID"
      ssh_port="$(host_port_for_guest "$PORT_FORWARDS_JSON" 22 tcp)"
      guest_ssh "$ssh_user" "$ssh_port" "$@"
      ;;
    console)
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      INSTANCE_ID="$(get_or_create_instance_id "$FLAKE_DIR" "$AS_NIXOS_ATTR")"
      require_running "$INSTANCE_ID"
      guest_console "$INSTANCE_ID"
      ;;
    logs)
      shift
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      INSTANCE_ID="$(get_or_create_instance_id "$FLAKE_DIR" "$AS_NIXOS_ATTR")"
      PORT_FORWARDS_JSON="$(nix eval --json \
        "${FLAKE_DIR}#nixosConfigurations.${AS_NIXOS_ATTR}.config.agentsandbox.portForwards")"
      require_running "$INSTANCE_ID"
      local logs_port=""
      logs_port="$(host_port_for_guest "$PORT_FORWARDS_JSON" 22 tcp)"
      if [[ "$#" -eq 0 ]]; then
        exec ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -p "$logs_port" \
          vscode@127.0.0.1 journalctl -en1000
      fi
      exec ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -p "$logs_port" \
        vscode@127.0.0.1 journalctl "$@"
      ;;
    stats)
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      INSTANCE_ID="$(get_or_create_instance_id "$FLAKE_DIR" "$AS_NIXOS_ATTR")"
      PORT_FORWARDS_JSON="$(nix eval --json \
        "${FLAKE_DIR}#nixosConfigurations.${AS_NIXOS_ATTR}.config.agentsandbox.portForwards")"
      require_running "$INSTANCE_ID"
      local stats_port="" stats_first="" stats_second="" stats_start_ns="" stats_end_ns="" stats_elapsed_ns=""
      local stats_cpu_1="" stats_cpu_2="" stats_mem_current="" stats_mem_max="" stats_net_rx_1="" stats_net_rx_2=""
      local stats_net_tx_1="" stats_net_tx_2="" stats_block_rd_1="" stats_block_rd_2="" stats_block_wr_1=""
      local stats_block_wr_2="" stats_cpu_pct="" stats_mem_pct="" stats_mem_usage="" stats_mem_limit=""
      local stats_net_io="" stats_block_io="" stats_pids=""

      stats_port="$(host_port_for_guest "$PORT_FORWARDS_JSON" 22 tcp)"
      stats_first="$(virsh domstats "$INSTANCE_ID")"
      stats_start_ns="$(date +%s%N)"
      sleep 1
      stats_second="$(virsh domstats "$INSTANCE_ID")"
      stats_end_ns="$(date +%s%N)"
      stats_elapsed_ns="$((stats_end_ns - stats_start_ns))"
      (( stats_elapsed_ns > 0 )) || stats_elapsed_ns=1

      stats_cpu_1="$(awk -F= '$1 == "cpu.time" { print $2; exit }' <<<"$stats_first")"
      stats_cpu_2="$(awk -F= '$1 == "cpu.time" { print $2; exit }' <<<"$stats_second")"
      stats_mem_current="$(awk -F= '$1 == "balloon.current" { print $2; exit }' <<<"$stats_second")"
      stats_mem_max="$(awk -F= '$1 == "balloon.maximum" { print $2; exit }' <<<"$stats_second")"
      stats_net_rx_1="$(awk -F= '$1 ~ /^net\.[0-9]+\.rx\.bytes$/ { sum += $2 } END { print sum + 0 }' <<<"$stats_first")"
      stats_net_rx_2="$(awk -F= '$1 ~ /^net\.[0-9]+\.rx\.bytes$/ { sum += $2 } END { print sum + 0 }' <<<"$stats_second")"
      stats_net_tx_1="$(awk -F= '$1 ~ /^net\.[0-9]+\.tx\.bytes$/ { sum += $2 } END { print sum + 0 }' <<<"$stats_first")"
      stats_net_tx_2="$(awk -F= '$1 ~ /^net\.[0-9]+\.tx\.bytes$/ { sum += $2 } END { print sum + 0 }' <<<"$stats_second")"
      stats_block_rd_1="$(awk -F= '$1 ~ /^block\.[0-9]+\.rd\.bytes$/ { sum += $2 } END { print sum + 0 }' <<<"$stats_first")"
      stats_block_rd_2="$(awk -F= '$1 ~ /^block\.[0-9]+\.rd\.bytes$/ { sum += $2 } END { print sum + 0 }' <<<"$stats_second")"
      stats_block_wr_1="$(awk -F= '$1 ~ /^block\.[0-9]+\.wr\.bytes$/ { sum += $2 } END { print sum + 0 }' <<<"$stats_first")"
      stats_block_wr_2="$(awk -F= '$1 ~ /^block\.[0-9]+\.wr\.bytes$/ { sum += $2 } END { print sum + 0 }' <<<"$stats_second")"

      stats_cpu_pct="$(
        awk -v before="${stats_cpu_1:-0}" -v after="${stats_cpu_2:-0}" -v elapsed="$stats_elapsed_ns" '
          BEGIN {
            if (elapsed <= 0 || after < before) {
              printf "0.00%%"
            } else {
              printf "%.2f%%", ((after - before) / elapsed) * 100
            }
          }
        '
      )"
      stats_mem_pct="$(
        awk -v current="${stats_mem_current:-0}" -v limit="${stats_mem_max:-0}" '
          BEGIN {
            if (limit <= 0 || current < 0) {
              printf "0.00%%"
            } else {
              printf "%.2f%%", (current / limit) * 100
            }
          }
        '
      )"
      stats_mem_usage="$(numfmt --to=iec-i --suffix=B "$(( ${stats_mem_current:-0} * 1024 ))")"
      stats_mem_limit="$(numfmt --to=iec-i --suffix=B "$(( ${stats_mem_max:-0} * 1024 ))")"
      stats_net_io="$(
        printf '%s / %s' \
          "$(numfmt --to=iec-i --suffix=B "$(( stats_net_rx_2 - stats_net_rx_1 ))")" \
          "$(numfmt --to=iec-i --suffix=B "$(( stats_net_tx_2 - stats_net_tx_1 ))")"
      )"
      stats_block_io="$(
        printf '%s / %s' \
          "$(numfmt --to=iec-i --suffix=B "$(( stats_block_rd_2 - stats_block_rd_1 ))")" \
          "$(numfmt --to=iec-i --suffix=B "$(( stats_block_wr_2 - stats_block_wr_1 ))")"
      )"
      if [[ -n "$stats_port" ]]; then
        stats_pids="$(
          ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -p "$stats_port" vscode@127.0.0.1 \
            sh -lc 'ps -e --no-headers | wc -l' 2>/dev/null | tr -d '[:space:]'
        )"
      fi
      [[ -n "${stats_pids:-}" ]] || stats_pids="-"
      printf '%-42s %8s %17s %8s %17s %17s %5s\n' \
        "NAME" "CPU %" "MEM USAGE / LIMIT" "MEM %" "NET I/O" "BLOCK I/O" "PIDS"
      printf '%-42s %8s %17s %8s %17s %17s %5s\n' \
        "$INSTANCE_ID" \
        "$stats_cpu_pct" \
        "${stats_mem_usage} / ${stats_mem_limit}" \
        "$stats_mem_pct" \
        "$stats_net_io" \
        "$stats_block_io" \
        "$stats_pids"
      ;;
    wait)
      shift
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      INSTANCE_ID="$(get_or_create_instance_id "$FLAKE_DIR" "$AS_NIXOS_ATTR")"
      RUNTIME_DIR="$RUNTIME_ROOT/$INSTANCE_ID"
      (($# == 0)) && set -- "shut off" crashed
      until is_domstate "$INSTANCE_ID" "$@"; do sleep 1; done
      cleanup_runtime_helpers "$RUNTIME_DIR"
      ;;
    allow-domain)
      shift
      [[ -n "${1:-}" ]] || die "usage: ${APP_NAME} allow-domain DOMAIN"
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      local allow_host=""

      # Normalize host/glob exactly like the proxy host matcher expects.
      allow_host="$1"
      allow_host="${allow_host#http://}"
      allow_host="${allow_host#https://}"
      allow_host="${allow_host%%/*}"
      if [[ "$allow_host" == \[* ]]; then
        allow_host="${allow_host#[}"
        allow_host="${allow_host%%]*}"
      else
        allow_host="${allow_host%%:*}"
      fi
      allow_host="${allow_host,,}"
      while [[ "$allow_host" == *"." ]]; do
        allow_host="${allow_host%.}"
      done
      [[ -n "$allow_host" ]] || die "empty domain"
      [[ -e "$FLAKE_DIR/allowed_hosts" ]] || cp "$TEMPLATE_DIR/allowed_hosts" "$FLAKE_DIR/allowed_hosts"
      if ! grep -Fxq -- "$allow_host" "$FLAKE_DIR/allowed_hosts" 2>/dev/null; then
        printf '%s\n' "$allow_host" >> "$FLAKE_DIR/allowed_hosts"
      fi
      ;;
    unallow-domain)
      shift
      [[ -n "${1:-}" ]] || die "usage: ${APP_NAME} unallow-domain DOMAIN"
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      local unallow_host="" unallow_tmp=""

      # Normalize host/glob exactly like the proxy host matcher expects.
      unallow_host="$1"
      unallow_host="${unallow_host#http://}"
      unallow_host="${unallow_host#https://}"
      unallow_host="${unallow_host%%/*}"
      if [[ "$unallow_host" == \[* ]]; then
        unallow_host="${unallow_host#[}"
        unallow_host="${unallow_host%%]*}"
      else
        unallow_host="${unallow_host%%:*}"
      fi
      unallow_host="${unallow_host,,}"
      while [[ "$unallow_host" == *"." ]]; do
        unallow_host="${unallow_host%.}"
      done
      [[ -e "$FLAKE_DIR/allowed_hosts" ]] || cp "$TEMPLATE_DIR/allowed_hosts" "$FLAKE_DIR/allowed_hosts"
      unallow_tmp="$(mktemp)"
      grep -Fxv -- "$unallow_host" "$FLAKE_DIR/allowed_hosts" > "$unallow_tmp" || true
      mv "$unallow_tmp" "$FLAKE_DIR/allowed_hosts"
      ;;
    mount)
      shift
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      if [[ "$#" -eq 0 ]]; then
        cat "$FLAKE_DIR/mounts"
        return 0
      fi
      local mount_src="" mount_name="" helper_pid=""

      mount_src="$(readlink -f "$1")"
      mount_name="${2:-$(basename "$mount_src")}"
      [[ -e "$mount_src" ]] || die "mount source does not exist: $mount_src"
      [[ "$mount_name" != */* ]] || die "guest mount name must not contain /"
      if awk -F $'\t' -v src="$mount_src" -v name="$mount_name" '
        /^[[:space:]]*#/ || NF == 0 { next }
        $1 == src && $2 == name { exact = 1; next }
        $1 == src || $2 == name { conflict = 1 }
        END {
          if (conflict) exit 2
          if (exact) exit 0
          exit 1
        }
      ' "$FLAKE_DIR/mounts"; then
        :
      elif [[ "$?" -eq 1 ]]; then
        printf '%s\t%s\n' "$mount_src" "$mount_name" >> "$FLAKE_DIR/mounts"
      else
        die "mount path or guest name is already assigned"
      fi
      INSTANCE_ID="$(get_or_create_instance_id "$FLAKE_DIR" "$AS_NIXOS_ATTR")"
      DATA_DIR="$DATA_ROOT/$INSTANCE_ID"
      RUNTIME_DIR="$RUNTIME_ROOT/$INSTANCE_ID"
      if [[ -r "$RUNTIME_DIR/mount-helper.pid" ]]; then
        helper_pid="$(<"$RUNTIME_DIR/mount-helper.pid")"
        if [[ -n "$helper_pid" ]] && kill -0 "$helper_pid" 2>/dev/null; then
          MUTABLE_SANDBOX_CONFIG="$(jq -r . <<<"$(nix eval --json \
            "${FLAKE_DIR}#nixosConfigurations.${AS_NIXOS_ATTR}.config.agentsandbox.mutableSandboxConfig")")"
          mount_workspace \
            "$helper_pid" \
            "$DATA_DIR/persistent" \
            "$FLAKE_DIR/mounts" \
            "$FLAKE_DIR" \
            "$MUTABLE_SANDBOX_CONFIG"
        fi
      fi
      ;;
    unmount)
      shift
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      [[ -n "${1:-}" ]] || die "usage: ${APP_NAME} unmount PATH"
      local unmount_src="" unmount_tmp="" helper_pid=""

      unmount_src="$(readlink -f "$1")"
      unmount_tmp="$(mktemp)"
      awk -F $'\t' -v src="$unmount_src" '
        /^[[:space:]]*#/ || NF == 0 { print; next }
        $1 != src { print }
      ' "$FLAKE_DIR/mounts" > "$unmount_tmp"
      mv "$unmount_tmp" "$FLAKE_DIR/mounts"
      INSTANCE_ID="$(get_or_create_instance_id "$FLAKE_DIR" "$AS_NIXOS_ATTR")"
      DATA_DIR="$DATA_ROOT/$INSTANCE_ID"
      RUNTIME_DIR="$RUNTIME_ROOT/$INSTANCE_ID"
      if [[ -r "$RUNTIME_DIR/mount-helper.pid" ]]; then
        helper_pid="$(<"$RUNTIME_DIR/mount-helper.pid")"
        if [[ -n "$helper_pid" ]] && kill -0 "$helper_pid" 2>/dev/null; then
          MUTABLE_SANDBOX_CONFIG="$(jq -r . <<<"$(nix eval --json \
            "${FLAKE_DIR}#nixosConfigurations.${AS_NIXOS_ATTR}.config.agentsandbox.mutableSandboxConfig")")"
          unmount_workspace \
            "$helper_pid" \
            "$DATA_DIR/persistent" \
            "$FLAKE_DIR/mounts" \
            "$FLAKE_DIR" \
            "$MUTABLE_SANDBOX_CONFIG"
        fi
      fi
      ;;
    proxy-logs)
      shift
      FLAKE_DIR="$(get_or_create_flake_dir "$PWD")"
      INSTANCE_ID="$(get_or_create_instance_id "$FLAKE_DIR" "$AS_NIXOS_ATTR")"
      STATE_DIR="$STATE_ROOT/$INSTANCE_ID"
      install -d "$STATE_DIR/logs"
      touch "$STATE_DIR/logs/requests.jsonl"
      for request_log in "$STATE_DIR"/logs/requests-*.jsonl.zst; do
        [[ -e "$request_log" ]] || continue
        zstd -dc -- "$request_log"
      done
      for request_log in "$STATE_DIR"/logs/requests-*.jsonl; do
        [[ -e "$request_log" && "$request_log" != "$STATE_DIR/logs/requests.jsonl" ]] || continue
        [[ ! -e "${request_log}.zst" ]] || continue
        cat -- "$request_log"
      done
      exec tail -n +1 -F "$STATE_DIR/logs/requests.jsonl"
      ;;
    verify)
      echo "TODO: nixos-rebuild --repair"
      echo "TODO: nix store verify --repair"
      ;;
    *)
      die "unknown subcommand: ${cmd:-<empty>}"
      ;;
  esac
}

main "$@"
