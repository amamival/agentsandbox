#           --set flow_detail=0 \
#           --set termlog_verbosity=warn \
#           -s "$proxy_addon" >>"$STATE_DIR/logs/runtime.log" 2>&1 &
#       proxy_pid="$!"
#       printf '%s\n' "$proxy_pid" > "$RUNTIME_DIR/proxy.pid"
#       for proxy_pid in $(seq 1 50); do
#         if [[ -f "$proxy_confdir/mitmproxy-ca-cert.pem" ]] \
#           && ss -ltnH "( sport = :${PROXY_PORT} )" | grep -q .; then
#           break
